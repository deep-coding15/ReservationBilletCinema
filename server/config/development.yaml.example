# Copier ce fichier en development.yaml et remplir avec les infos de la base cloud.
# Ne jamais commiter development.yaml (il est dans .gitignore).

# Exemple Neon : host = ep-xxx-xxx.region.aws.neon.tech
# Exemple Supabase : host = db.xxxxxxxx.supabase.co
database:
  host: __HOST_DU_CLOUD__
  port: 5432
  name: __NOM_DE_LA_BASE__
  username: __USER__
  password: __MOT_DE_PASSE__
  ssl: true

server:
  port: 8080
  host: 0.0.0.0

logging:
  level: info
